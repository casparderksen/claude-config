{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Read(~/.m2/settings.xml)",
      "Edit(~/.m2/settings.xml)",
      "Edit(~/.zshrc)",
      "Edit(~/.zprofile)",
      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(http *)",
      "Bash(httpie *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "central.maven.org",
        "repo1.maven.org",
        "oss.sonatype.org",
        "plugins.gradle.org",
        "jitpack.io",
        "registry.npmjs.org",
        "*.npmjs.org"
      ]
    }
  }
}
